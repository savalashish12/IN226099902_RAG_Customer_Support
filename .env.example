# ── API Keys ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Settings ──────────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE=900
CHUNK_OVERLAP=100
MAX_CHUNKS=60

# ── Retrieval ─────────────────────────────────────────────────
TOP_K=5

# ── Confidence Thresholds (L2 Distance) ───────────────────────
# Lower L2 distance = more relevant
HIGH_CONF_THRESHOLD=0.30     # score < 0.30 → HIGH
MEDIUM_CONF_THRESHOLD=0.55   # 0.30 ≤ score < 0.55 → MEDIUM
# score ≥ 0.55 → LOW → always HITL

# ── Embedding ─────────────────────────────────────────────────
EMBEDDING_BATCH_SIZE=25
EMBEDDING_DELAY_SECONDS=5
